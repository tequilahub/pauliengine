# Generated by setuptools-scm on every build — never edit or commit.
src/pauliengine/_version.py

# Benchmark results are host-specific — CPU model, thread count, and
# pauliengine version are baked into every JSON, so committing them would
# cause spurious noise across machines.
tools/benchmarks/results/*
!tools/benchmarks/results/.gitkeep
CMakeUserPresets.json
